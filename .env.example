# =============================================================================
# TEXT-TO-SQL DEMO — Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1

# --- LangSmith (LLM Observability) ---
# Get your key at https://smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=text-to-sql-demo-dev

# --- Database ---
# Dev (SQLite — auto-created by seed script)
DB_URL=sqlite+aiosqlite:///./data/seeds/dev.db
# Prod (PostgreSQL — used by Docker Compose postgres service)
# DB_URL=postgresql+asyncpg://nedbank:nedbank_pass@db:5432/nedbankdb

# --- MLflow ---
MLFLOW_TRACKING_URI=file:./mlruns
# Start the UI with: .venv/bin/python -m mlflow ui --backend-store-uri ./mlruns --port 5000

# --- App ---
ENVIRONMENT=development
BACKEND_URL=http://localhost:8000
# Docker Compose frontend uses: http://backend:8000

# --- Security ---
# Secret key for signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-generate-a-real-secret-key

# --- Postgres (used by Docker Compose) ---
POSTGRES_USER=nedbank
POSTGRES_PASSWORD=nedbank_pass
POSTGRES_DB=nedbankdb
